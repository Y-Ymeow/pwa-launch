{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PWA Container",
  "version": "0.1.0",
  "identifier": "com.pwa.container",
  "build": {
    "frontendDist": "dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "PWA Container",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src *; script-src * 'unsafe-inline' 'unsafe-eval'; style-src * 'unsafe-inline'; img-src * data: blob:; font-src *; connect-src *; frame-src *;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/48x48.png",
      "icons/72x72.png",
      "icons/96x96.png",
      "icons/144x144.png",
      "icons/192x192.png",
      "icons/512x512.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "category": "Utility"
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    }
  }
}
