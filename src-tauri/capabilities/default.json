{
  "$schema": "https://schema.tauri.app/config/2/capabilities",
  "identifier": "main-capability",
  "description": "Default capability for the app",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "shell:default",
    "fs:default",
    "dialog:default",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "https://*"
        },
        {
          "url": "http://*"
        }
      ]
    },
    "os:default",
    "log:default",
    "sql:default",
    "sql:allow-execute",
    "store:default",
    "allow-audio-play",
    "allow-audio-pause",
    "allow-audio-resume",
    "allow-audio-stop",
    "allow-audio-set-volume",
    "allow-audio-get-state",
    "allow-audio-get-position",
    "allow-audio-get-duration",
    "allow-audio-seek",
    "allow-audio-get-current-url",
    "allow-audio-set-loop",
    "allow-open-file-dialog",
    "allow-read-file-content",
    "allow-read-file-range",
    "shell:allow-open",
    "audioplayer:default",
    "allow-clear-webview-cache-data",
    "http:allow-fetch",
    "http:allow-fetch-cancel",
    "http:allow-fetch-cancel-body",
    "http:allow-fetch-read-body",
    "http:allow-fetch-send",
    {
      "identifier": "fs:allow-app-read-recursive",
      "allow": [
        {
          "path": "$APPDATA"
        },
        {
          "path": "$APPDATA/**/*"
        },
        {
          "path": "$APPCONFIG*"
        },
        {
          "path": "$APPCONFIG/**/*"
        },
        {
          "path": "$APPLOCALDATA"
        },
        {
          "path": "$APPLOCALDATA/**/*"
        },
        {
          "path": "$APPCACHE"
        },
        {
          "path": "$APPCACHE/**/*"
        },
        {
          "path": "$APPLOG"
        },
        {
          "path": "$APPLOG/**/*"
        },
        {
          "path": "$RESOURCE"
        },
        {
          "path": "$RESOURCE/**/*"
        },
        {
          "path": "$APPCACHE"
        },
        {
          "path": "$APPCACHE/**/*"
        },
        {
          "path": "$APPLOG"
        },
        {
          "path": "$APPLOG/**/*"
        },
        {
          "path": "$AUDIO"
        },
        {
          "path": "$AUDIO/**/*"
        },
        {
          "path": "$CACHE"
        },
        {
          "path": "$CACHE/**/*"
        },
        {
          "path": "$CONFIG"
        },
        {
          "path": "$CONFIG/**/*"
        },
        {
          "path": "$DATA"
        },
        {
          "path": "$DATA/**/*"
        },
        {
          "path": "$LOCALDATA"
        },
        {
          "path": "$LOCALDATA/**/*"
        },
        {
          "path": "$DESKTOP"
        },
        {
          "path": "$DESKTOP/**/*"
        },
        {
          "path": "$DOCUMENT"
        },
        {
          "path": "$DOCUMENT/**/*"
        },
        {
          "path": "$DOWNLOAD"
        },
        {
          "path": "$DOWNLOAD/**/*"
        },
        {
          "path": "$PICTURE"
        },
        {
          "path": "$PICTURE/**/*"
        },
        {
          "path": "$PUBLIC"
        },
        {
          "path": "$PUBLIC/**/*"
        },
        {
          "path": "$VIDEO"
        },
        {
          "path": "$VIDEO/**/*"
        },
        {
          "path": "$RESOURCE"
        },
        {
          "path": "$RESOURCE/**/*"
        },
        {
          "path": "/computer/Music"
        },
        {
          "path": "/computer/Music/**/*"
        },
        {
          "path": "/computer/Downloads"
        },
        {
          "path": "/computer/Downloads/**/*"
        }
      ]
    },
    "fs:default",
    "fs:read-all",
    "fs:write-all",
    "fs:allow-mkdir",
    "fs:allow-read-dir"
  ]
}
