{
  "$schema": "https://schema.tauri.app/config/2/capabilities",
  "identifier": "main-capability",
  "description": "Default capability for the app",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "shell:default",
    {
      "identifier": "fs:default"
    },
    {
      "identifier": "fs:allow-read-file",
      "allow": [
        {
          "path": "**"
        },
        {
          "path": "$AUDIO/**"
        },
        {
          "path": "$VIDEO/**"
        }
      ]
    },
    {
      "identifier": "http:default",
      "allow": [{ "url": "fs://**" }]
    },
    "allow-install-pwa",
    "allow-uninstall-pwa",
    "allow-list-apps",
    "allow-launch-app",
    "allow-close-pwa-window",
    "allow-list-running-pwas",
    "allow-clear-data",
    "allow-backup-data",
    "allow-restore-data",
    "allow-get-app-info",
    "allow-update-pwa",
    "allow-proxy-fetch",
    "allow-get-cookies",
    "allow-set-cookies",
    "allow-clear-cookies",
    "allow-get-all-cookies",
    "allow-set-proxy",
    "allow-get-proxy",
    "allow-disable-proxy",
    "allow-opfs-write-file",
    "allow-opfs-read-file",
    "allow-opfs-delete-file",
    "allow-opfs-list-dir",
    "allow-resolve-local-file-url",
    "allow-open-file-dialog",
    "allow-read-file-content",
    "allow-read-file-range",
    "allow-kv-get-all",
    "allow-kv-set",
    "allow-kv-get",
    "allow-kv-remove",
    "allow-kv-clear",
    "allow-fs-read-dir",
    "allow-fs-write-file",
    "allow-fs-create-dir",
    "allow-fs-remove",
    "allow-fs-exists",
    "allow-check-storage-permission",
    "allow-request-storage-permission",
    "allow-sync-webview-cookies",
    "allow-navigate-to-url",
    "allow-navigate-back",
    "allow-get-webview-info",
    "allow-reinject-browser-ui",
    "allow-check-browser-ui",
    "allow-eval-js",
    "os:default",
    "log:default",
    "dialog:default",
    "shell:allow-open"
  ]
}
