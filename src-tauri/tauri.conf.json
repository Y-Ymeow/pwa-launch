{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PWA Container",
  "version": "0.2.0",
  "identifier": "com.pwa.container",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": {
        "default-src": "* http://* https://*",
        "standard-src": "*",
        "script-src": "*",
        "style-src": "*",
        "img-src": "*",
        "media-src": "*",
        "connect-src": "*",
        "font-src": "*"
      },
      "dangerousDisableAssetCspModification": true,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**",
          "$AUDIO/**",
          "$HOME/**",
          "$HOME/Music/**",
          "$HOME/Videos/**",
          "$HOME/音乐/**",
          "$HOME/视频/**",
          "$HOME/Pictures/**",
          "$HOME/图片/**",
          "$HOME/Downloads/**",
          "$HOME/下载/**",
          "$HOME/Documents/**",
          "$HOME/文档/**",
          "/computer/**",
          "/computer/Music/**",
          "/computer/Videos/**",
          "/computer/Pictures/**",
          "/computer/Downloads/**",
          "/computer/Documents/**",
          "$VIDEO/**",
          "$PICTURE/**",
          "$DOCUMENT/**",
          "$DOWNLOAD/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/48x48.png",
      "icons/72x72.png",
      "icons/96x96.png",
      "icons/144x144.png",
      "icons/192x192.png",
      "icons/512x512.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "category": "Utility",
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    }
  }
}
