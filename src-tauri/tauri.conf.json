{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PWA Container",
  "version": "0.1.0",
  "identifier": "com.pwa.container",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PWA Container",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "transparent": false,
        "devtools": true,
        "visible": true,
        "useHttpsScheme": false
      }
    ],
    "security": {
      "csp": {},
      "dangerousDisableAssetCspModification": true,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**",
          "$AUDIO/**",
          "$VIDEO/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/48x48.png",
      "icons/72x72.png",
      "icons/96x96.png",
      "icons/144x144.png",
      "icons/192x192.png",
      "icons/512x512.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "category": "Utility",
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    }
  }
}
